# Hindsight Local Manager stores runtime config in:
# %LOCALAPPDATA%\HindsightLocalManager\config.json

# These values document defaults only; the app does not require a project .env.
HINDSIGHT_MANAGER_BRIDGE_HOST=127.0.0.1
HINDSIGHT_MANAGER_BRIDGE_PORT=17331
HINDSIGHT_MANAGER_API_PORT=8888
HINDSIGHT_MANAGER_UI_PORT=9999
HINDSIGHT_MANAGER_DEFAULT_MODEL=github-copilot/gpt-5.4-mini
